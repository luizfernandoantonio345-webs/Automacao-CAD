# .env.example - Copie para .env e preencha valores reais
# Nunca commite .env com senhas reais!

# JWT Secret (gere com: python -c "import secrets; print(secrets.token_urlsafe(64))")
JARVIS_SECRET=super-secret-key-change-in-production-min32bytes1234567890abcdef

# Rate limits
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_REGISTER_PER_MINUTE=3

# Redis
REDIS_PASS=redis_secure_pass_2024

# RabbitMQ
RABBITMQ_USER=cad_user
RABBITMQ_PASS=rabbitmq_secure_pass_2024

# Grafana
GRAFANA_ADMIN_PASS=admin123_change_me

# App
APP_ENV=production
MAX_EXCEL_UPLOAD_MB=15
