# Environment Variables for Engenharia Automacao CAD
# Copy this file to .env and fill with secure values

# Authentication Secrets
ENG_AUTH_SECRET=your_secure_random_auth_secret_here_32_chars_min
JARVIS_SECRET=your_secure_random_jarvis_secret_here_32_chars_min
LICENSE_SECRET=your_secure_random_license_secret_here_32_chars_min

# Database — descomente para usar PostgreSQL em produção
# DATABASE_URL=postgresql://user:password@localhost:5432/engenharia_db

# Redis (Future)
# REDIS_URL=redis://localhost:6379

# Application Settings
# IMPORTANTE: Em production, JARVIS_SECRET é OBRIGATÓRIO (>= 32 bytes)
APP_ENV=development
LOG_LEVEL=INFO
ALLOW_DEMO_LOGIN=true

# Licensing
LICENSE_FALLBACK_ENABLED=true

# File Upload Limits
MAX_EXCEL_UPLOAD_MB=15
MAX_LISP_FILES_HISTORY=200

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_LICENSING_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REGISTER_PER_MINUTE=3

# Admin padrão (primeiro uso)
# ENGCAD_ADMIN_PASSWORD=change_me_on_first_deploy