{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Jobs CAM processados",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Jobs CAM / Hora",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(cam_jobs_completed_total[1h]) * 3600",
          "legendFormat": "Jobs/hora",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "G-code gerado em KB",
      "fieldConfig": {
        "defaults": {
          "unit": "decKbytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "title": "G-code Gerado",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(gcode_output_bytes) / 1024",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Eficiência do nesting",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "green", "value": 85}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "title": "Eficiência Nesting",
      "type": "gauge",
      "targets": [
        {
          "expr": "avg(nesting_efficiency) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Tempo médio de geração de G-code",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "title": "Tempo de Geração G-code",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(gcode_generation_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(gcode_generation_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Distribuição de materiais",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "title": "Jobs por Material",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum by (material) (cam_jobs_by_material)",
          "legendFormat": "{{material}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Peças processadas por tipo",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "title": "Peças por Tipo",
      "type": "barchart",
      "targets": [
        {
          "expr": "sum by (piece_type) (pieces_processed_total)",
          "legendFormat": "{{piece_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Erros de validação",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 7,
      "title": "Erros de Validação",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "expr": "rate(cam_validation_errors_total[5m]) * 60",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Área de chapa utilizada vs desperdiçada",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "title": "Utilização de Chapa (m²)",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "unit": "m2"
        }
      },
      "targets": [
        {
          "expr": "sheet_area_used_m2",
          "legendFormat": "Utilizado",
          "refId": "A"
        },
        {
          "expr": "sheet_area_waste_m2",
          "legendFormat": "Desperdício",
          "refId": "B"
        }
      ]
    }
  ],
