{
  "name": "engenharia-automacao-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "public/electron.js",
  "scripts": {
    "dev": "react-scripts start",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "electron": "concurrently \"npm:start\" \"wait-on http://localhost:3000 && .\\node_modules\\electron\\dist\\electron.exe .\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "axios": "^1.5.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "5.0.1",
    "sweetalert2": "^11.7.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.0",
    "electron": "^41.2.0",
    "electron-builder": "^24.8.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.5",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.engenharia.automacao",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "build/**/*",
      "public/**/*",
      "src/**/*",
      "package.json"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
